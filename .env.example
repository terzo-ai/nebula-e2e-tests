# All tests hit mafia.terzocloud.com (Dev environment)
E2E_BASE_URL=https://mafia.terzocloud.com
E2E_TENANT_ID=1000012

# Access token — auto-fetched from auth service when running in Dev cluster
E2E_ACCESS_TOKEN=

# Auth service (reachable from Dev cluster only)
E2E_AUTH_SERVICE_URL=https://auth-service-dev.product-internal.terzocloud.com
E2E_AUTH_SERVICE_KEY=9a264959-4f45-43a2-aaa2-ea30c9817af4
E2E_AUTH_USER_ID=1001359
E2E_AUTH_EMAIL=shankar@terzocloud.com

# Test file source (checked in order: dir → azure blob → in-memory fallback)
# Option 1: Mounted Azure File Share or local directory with PDFs
E2E_FIXTURES_DIR=/mnt/e2e-fixtures
# Option 2: Azure Blob container
# E2E_FIXTURES_CONNECTION_STRING=
# E2E_FIXTURES_CONTAINER=e2e-test-fixtures

# Timeouts
E2E_FULL_PIPELINE_TIMEOUT=600
E2E_POLL_INTERVAL=2.0

# Event Hub (optional — enables event capture during E2E tests)
# E2E_EVENT_HUB_CONNECTION_STRING=Endpoint=sb://...
# E2E_EVENT_HUB_NAME=nebula-pipeline-events
# E2E_EVENT_HUB_CONSUMER_GROUP=probe-test
# E2E_EVENT_HUB_LISTEN_TIMEOUT=120.0

# Pipeline report output directory
# E2E_REPORT_OUTPUT_DIR=reports
